import os
import json
import torch
import faiss
import numpy as np
from pathlib import Path
from transformers import CLIPProcessor, CLIPModel

# --- CONFIGURATION ---
EMBEDDING_MODEL = "clip"
TOP_K = 5

BASE_DIR = Path(__file__).parent.parent
DATA_DIR = BASE_DIR / "data"

INDEX_FILE = DATA_DIR / f"{EMBEDDING_MODEL}_faiss_index.bin"
MAPPING_FILE = DATA_DIR / f"{EMBEDDING_MODEL}_image_mapping.json"
METADATA_FILE = DATA_DIR / "metadata.jsonl"

device = "cuda" if torch.cuda.is_available() else "cpu"

def load_system():
    print(f"Loading {EMBEDDING_MODEL.upper()} model on {device}...")
    if EMBEDDING_MODEL == "clip":
        model_id = "openai/clip-vit-base-patch32"
        processor = CLIPProcessor.from_pretrained(model_id)
        model = CLIPModel.from_pretrained(model_id).to(device)
    else:
        raise ValueError(f"Unknown model: {EMBEDDING_MODEL}")
    
    model.eval()
    
    print(f"Loading FAISS Index from {INDEX_FILE.name}...")
    if not INDEX_FILE.exists():
        raise FileNotFoundError(f"Missing index at {INDEX_FILE}. Did you run build_index.py?")
    index = faiss.read_index(str(INDEX_FILE))
    
    print(f"Loading Image Mapping from {MAPPING_FILE.name}...")
    with open(MAPPING_FILE, "r", encoding="utf-8") as f:
        image_mapping = json.load(f)
        
    print("Loading Metadata...")
    metadata_map = {}
    with open(METADATA_FILE, "r", encoding="utf-8") as f:
        for line in f:
            record = json.loads(line)
            metadata_map[record["image_id"]] = record
            
    return processor, model, index, image_mapping, metadata_map

@torch.no_grad()
def search(query, processor, model, index, image_mapping, metadata_map):
    print(f"\nSearching for: '{query}'")
    
    # 1. Embed the text query
    inputs = processor(text=[query], return_tensors="pt", padding=True).to(device)
    
    # Extract text features
    if EMBEDDING_MODEL == "clip":
        text_embeds = model.get_text_features(**inputs)
    
    # 2. Normalize L2 to match the Image Embeddings
    text_embeds = text_embeds / text_embeds.norm(p=2, dim=-1, keepdim=True)
    emb_np = text_embeds.cpu().numpy().astype('float32')
    
    # 3. FAISS Search
    scores, indices = index.search(emb_np, TOP_K)
    
    # 4. Display Results
    print(f"\n--- TOP {TOP_K} RESULTS ---")
    for i in range(TOP_K):
        vector_idx = str(indices[0][i]) # JSON keys are strings
        score = scores[0][i]
        
        image_id = image_mapping.get(vector_idx, "UNKNOWN_ID")
        meta = metadata_map.get(image_id, {})
        
        print(f"Rank {i+1} | Score: {score:.4f} | Image ID: {image_id}")
        
        # Print relevant metadata for context
        if meta:
            if meta.get("garments"):
                print(f"         Garments: {', '.join(meta['garments'])}")
            if meta.get("colors"):
                print(f"         Colors:   {', '.join(meta['colors'])}")
            if meta.get("scene"):
                print(f"         Scene:    {meta['scene']}")
        print()

def interactive_loop():
    processor, model, index, image_mapping, metadata_map = load_system()
    
    print("\n" + "="*50)
    print("🔍 CLIP-FAISS Interactive Retriever")
    print("="*50)
    
    while True:
        try:
            query = input("\nEnter search query (or 'quit' to exit): ").strip()
            if not query:
                continue
            if query.lower() in ['quit', 'exit', 'q']:
                print("Exiting...")
                break
                
            search(query, processor, model, index, image_mapping, metadata_map)
            
        except KeyboardInterrupt:
            print("\nExiting...")
            break
        except Exception as e:
            print(f"Error during search: {e}")

if __name__ == "__main__":
    interactive_loop()

